createToggle(miscContent, 148, "Auto Coins sammeln", function(state)
    RunService.Heartbeat:Connect(function()
        if not state then return end
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        for _, obj in pairs(workspace:GetDescendants()) do
            if (obj.Name == "Coin" or obj.Name == "CoinDrop") and obj:IsA("BasePart") then
                if (hrp.Position - obj.Position).Magnitude < 50 then
                    hrp.CFrame = CFrame.new(obj.Position)
                end
            end
        end
    end)
end)

