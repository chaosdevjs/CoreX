local highlights = {}

createToggle(espContent, 10, "Player Highlight ESP", function(state)
    for _, h in pairs(highlights) do if h and h.Parent then h:Destroy() end end
    highlights = {}
    StatusLabel.Text = state and "● ESP: Aktiv" or "● Status: Bereit"
    StatusLabel.TextColor3 = state and Color3.fromRGB(255,100,100) or Color3.fromRGB(50,220,100)
    if state then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local hl = Instance.new("Highlight")
                hl.Adornee = player.Character
                hl.FillColor = Color3.fromRGB(255, 50, 50)
                hl.OutlineColor = Color3.fromRGB(255, 0, 0)
                hl.FillTransparency = 0.5
                hl.Parent = player.Character
                table.insert(highlights, hl)
            end
        end
    end
end)

createToggle(espContent, 56, "Nametags anzeigen", function(state) end)
createToggle(espContent, 102, "Rollen ESP (Mörder/Sheriff)", function(state) end)
createToggle(espContent, 148, "Tracer Lines", function(state) end)

