ESPTab:CreateSection("🔴 Mörder = Rot  |  🔵 Sheriff = Blau  |  🟢 Normal = Grün")

local highlights = {}
local espActive = false

local function clearHighlights()
    for _, h in pairs(highlights) do
        if h and h.Parent then h:Destroy() end
    end
    highlights = {}
end

local function applyHighlights()
    clearHighlights()
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local hl = Instance.new("Highlight")
            hl.Adornee = player.Character
            local tool = player.Character:FindFirstChildOfClass("Tool")
            if tool then
                local n = tool.Name:lower()
                if n:find("knife") or n:find("blade") or n:find("murder") then
                    hl.FillColor = Color3.fromRGB(255, 30, 30)
                    hl.OutlineColor = Color3.fromRGB(200, 0, 0)
                elseif n:find("gun") or n:find("sheriff") then
                    hl.FillColor = Color3.fromRGB(30, 100, 255)
                    hl.OutlineColor = Color3.fromRGB(0, 60, 200)
                else
                    hl.FillColor = Color3.fromRGB(30, 220, 80)
                    hl.OutlineColor = Color3.fromRGB(0, 180, 50)
                end
            else
                hl.FillColor = Color3.fromRGB(30, 220, 80)
                hl.OutlineColor = Color3.fromRGB(0, 180, 50)
            end
            hl.FillTransparency = 0.4
            hl.OutlineTransparency = 0
            hl.Parent = player.Character
            table.insert(highlights, hl)
        end
    end
end

RunService.Heartbeat:Connect(function()
    if espActive then applyHighlights() end
end)

