-- TOGGLE FUNKTION
local function createToggle(parent, yPos, labelText, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -20, 0, 38)
    frame.Position = UDim2.new(0, 10, 0, yPos)
    frame.BackgroundColor3 = Color3.fromRGB(28, 28, 38)
    frame.BorderSizePixel = 0
    frame.Parent = parent

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 7)
    corner.Parent = frame

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -60, 1, 0)
    label.Position = UDim2.new(0, 12, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = labelText
    label.TextColor3 = Color3.fromRGB(210, 210, 220)
    label.TextSize = 13
    label.Font = Enum.Font.Gotham
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame

    local togBg = Instance.new("Frame")
    togBg.Size = UDim2.new(0, 42, 0, 22)
    togBg.Position = UDim2.new(1, -54, 0.5, -11)
    togBg.BackgroundColor3 = Color3.fromRGB(50, 50, 65)
    togBg.BorderSizePixel = 0
    togBg.Parent = frame

    local togCorner = Instance.new("UICorner")
    togCorner.CornerRadius = UDim.new(1, 0)
    togCorner.Parent = togBg

    local togDot = Instance.new("Frame")
    togDot.Size = UDim2.new(0, 16, 0, 16)
    togDot.Position = UDim2.new(0, 3, 0.5, -8)
    togDot.BackgroundColor3 = Color3.fromRGB(150, 150, 170)
    togDot.BorderSizePixel = 0
    togDot.Parent = togBg

    local dotCorner = Instance.new("UICorner")
    dotCorner.CornerRadius = UDim.new(1, 0)
    dotCorner.Parent = togDot

    local enabled = false
    local clickDetect = Instance.new("TextButton")
    clickDetect.Size = UDim2.new(1, 0, 1, 0)
    clickDetect.BackgroundTransparency = 1
    clickDetect.Text = ""
    clickDetect.Parent = frame

    clickDetect.MouseButton1Click:Connect(function()
        enabled = not enabled
        if enabled then
            TweenService:Create(togBg, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(180, 0, 0)}):Play()
            TweenService:Create(togDot, TweenInfo.new(0.2), {Position = UDim2.new(0, 23, 0.5, -8), BackgroundColor3 = Color3.fromRGB(255,255,255)}):Play()
            label.TextColor3 = Color3.fromRGB(255, 255, 255)
        else
            TweenService:Create(togBg, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(50, 50, 65)}):Play()
            TweenService:Create(togDot, TweenInfo.new(0.2), {Position = UDim2.new(0, 3, 0.5, -8), BackgroundColor3 = Color3.fromRGB(150,150,170)}):Play()
            label.TextColor3 = Color3.fromRGB(210, 210, 220)
        end
        if callback then callback(enabled) end
    end)
end

