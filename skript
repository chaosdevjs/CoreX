local FarmTab = Window:CreateTab("🌾 Autofarm", 4483362458)
FarmTab:CreateSection("Coins Farmen")

local farmActive = false
local farmSpeed = 60
local flingWhenDone = false
local resetWhenFull = false
local coinConnection = nil

local function stopFarm()
    farmActive = false
    if coinConnection then
        coinConnection:Disconnect()
        coinConnection = nil
    end
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.WalkSpeed = 16 end
    end
end

local function startFarm()
    farmActive = true
    if coinConnection then coinConnection:Disconnect() end
    coinConnection = RunService.Heartbeat:Connect(function()
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then return end
        hum.WalkSpeed = farmSpeed
        local coinNames = {"Coin", "coin", "CoinDrop", "GoldCoin", "Value", "Drop"}
        local nearest, nearDist = nil, math.huge
        for _, obj in pairs(workspace:GetDescendants()) do
            for _, name in pairs(coinNames) do
                if obj.Name:lower():find(name:lower()) then
                    local part = nil
                    if obj:IsA("BasePart") or obj:IsA("MeshPart") then
                        part = obj
                    elseif obj:IsA("Model") then
                        part = obj.PrimaryPart or obj:FindFirstChildOfClass("BasePart")
                    end
                    if part then
                        local d = (hrp.Position - part.Position).Magnitude
                        if d < nearDist then nearDist = d; nearest = part end
                    end
                    break
                end
            end
        end
        if nearest then
            hrp.CFrame = CFrame.new(nearest.Position + Vector3.new(0,2,0))
        else
            if resetWhenFull then
                stopFarm()
                Rayfield:Notify({ Title = "🌾 Farm", Content = "Keine Coins! Reset...", Duration = 3, Image = 4483362458 })
                wait(1)
                LocalPlayer:LoadCharacter()
            end
        end
    end)
end

FarmTab:CreateToggle({
    Name = "Toggle Autofarm",
    CurrentValue = false,
    Flag = "AutoFarm",
    Callback = function(state)
        if state then
            startFarm()
            Rayfield:Notify({ Title = "🌾 Autofarm", Content = "✅ Gestartet!", Duration = 3, Image = 4483362458 })
        else
            stopFarm()
            Rayfield:Notify({ Title = "🌾 Autofarm", Content = "❌ Gestoppt!", Duration = 3, Image = 4483362458 })
