local function ApplyWeaponSkin(name)
    local skin = WeaponSkins[name]
    if not skin then return end
    local char = LocalPlayer.Character
    if not char then return end
    for _, tool in pairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            for _, part in pairs(tool:GetDescendants()) do
                if part:IsA("BasePart") or part:IsA("MeshPart") then
                    pcall(function()
                        local mesh = part:FindFirstChildOfClass("SpecialMesh")
                        if mesh then mesh.TextureId = skin.primary
                        else
                            local d = part:FindFirstChildOfClass("Decal") or Instance.new("Decal", part)
                            d.Texture = skin.primary
                        end
                    end)
                end
            end
        end
    end
end

local function ApplyGearSkin(name)
    local tex = GearSkins[name]
    if not tex then return end
    local char = LocalPlayer.Character
    if not char then return end
    for _, obj in pairs(char:GetDescendants()) do
        if obj:IsA("BasePart") then
            pcall(function()
                local mesh = obj:FindFirstChildOfClass("SpecialMesh")
                if mesh then mesh.TextureId = tex end
            end)
        end
    end
end

