-- Fly Toggle
local flyBody
PlayerTab:AddToggle({
    Name = "Fly",
    Default = false,
    Save = true,
    Flag = "FlyToggle",
    Callback = function(val)
        state.flyEnabled = val
        if val then
            -- Fly implementation
            local bg = Instance.new("BodyGyro", RootPart)
            bg.P = 9e4; bg.maxTorque = Vector3.new(9e9, 9e9, 9e9); bg.CFrame = RootPart.CFrame
            local bv = Instance.new("BodyVelocity", RootPart)
            bv.Velocity = Vector3.zero; bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
            flyBody = { bg = bg, bv = bv }

            local cam = workspace.CurrentCamera
            RunService:BindToRenderStep("FlyEH", 300, function()
                if not state.flyEnabled then return end
                local cf = cam.CFrame
                local dir = Vector3.zero
                local uis = game:GetService("UserInputService")
                if uis:IsKeyDown(Enum.KeyCode.W) then dir = dir + cf.LookVector end
                if uis:IsKeyDown(Enum.KeyCode.S) then dir = dir - cf.LookVector end
                if uis:IsKeyDown(Enum.KeyCode.A) then dir = dir - cf.RightVector end
                if uis:IsKeyDown(Enum.KeyCode.D) then dir = dir + cf.RightVector end
                if uis:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.yAxis end
                if uis:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir - Vector3.yAxis end
                bv.Velocity = dir * state.flySpeed
                bg.CFrame = cf
            end)
        else
            RunService:UnbindFromRenderStep("FlyEH")
            if flyBody then
                flyBody.bg:Destroy()
                flyBody.bv:Destroy()
                flyBody = nil
            end
        end
    end
})

